{
  "expo": {
    "name": "shOk",
    "slug": "shok-delivery",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shok.delivery",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.shok.delivery",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-adaptive.png",
        "backgroundColor": "#000000"
      },
      "newArchEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ]
  }
}
