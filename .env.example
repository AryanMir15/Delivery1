# ============================================
# shOk - Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).

# === DATABASE ===
# Get from: https://cloud.mongodb.com → Database → Connect → Application
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?appName=shOk
MONGO_URI=

# === SERVER ===
PORT=4000
NODE_ENV=development

# === AUTH (JWT) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# === EMAIL (Nodemailer via Gmail SMTP) ===
# Set ENABLE_EMAIL=false to disable email sending (recommended for dev)
# For Gmail: enable 2FA → App Passwords → generate one
ENABLE_EMAIL=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
FROM_EMAIL=noreply@shok.app
FRONTEND_URL=http://localhost:3000
DEFAULT_EMAIL_NAME=shOk
DEFAULT_EMAIL=noreply@shok.app

# === MAPS (MapTiler) ===
# Get from: https://cloud.maptiler.com → API Keys → Create
MAPTILER_API_KEY=

# === PAYMENTS (Phase 1: COD only) ===
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=http://localhost:4000/payment/verify
CHAPA_RETURN_URL=http://localhost:3000/payment-success

# === SMS / OTP ===
SKIP_WHATSAPP_OTP=true

# === FIREBASE (Push Notifications - Phase 2+) ===
FIREBASE_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
VAPID_KEY=

# === GOOGLE MAPS (using OSRM instead) ===
GOOGLE_API_KEY=
